"""
Open-Meteo API client with caching and error handling
"""

import aiohttp
from datetime import datetime
from typing import Optional, Dict, List
from config import WEATHER_API_BASE, TIMEZONE

# Simple in-memory cache
_cache = {}

async def get_forecast_7day(latitude: float, longitude: float) -> Optional[Dict]:
    """
    Get 7-day weather forecast from Open-Meteo API
    
    Args:
        latitude: Latitude in degrees
        longitude: Longitude in degrees
    
    Returns:
        Weather data dictionary or None if error
    """
    cache_key = f"7day_{latitude}_{longitude}"
    
    # Check cache
    if cache_key in _cache:
        cached_data, timestamp = _cache[cache_key]
        # Cache for 30 minutes
        if (datetime.now() - timestamp).seconds < 1800:
            return cached_data
    
    url = (
        f"{WEATHER_API_BASE}?"
        f"latitude={latitude}&longitude={longitude}"
        f"&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max"
        f"&timezone={TIMEZONE}"
        f"&forecast_days=7"
    )
    
    async with aiohttp.ClientSession() as session:
        try:
            async with session.get(url, timeout=aiohttp.ClientTimeout(total=10)) as response:
                if response.status == 200:
                    data = await response.json()
                    # Cache the result
                    _cache[cache_key] = (data, datetime.now())
                    return data
                else:
                    return None
        except Exception as e:
            return None

